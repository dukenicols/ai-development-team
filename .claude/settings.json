{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Agent(user-proxy)",
      "Agent(project-manager)",
      "Agent(backend-developer)",
      "Agent(frontend-developer)",
      "Agent(mobile-developer)",
      "Agent(database-engineer)",
      "Agent(qa-engineer)",
      "Agent(Explore)",
      "Agent(Plan)",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git worktree:*)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date -u +%Y-%m-%dT%H:%M:%SZ)] Agent completed\" >> .claude/agent-activity.log"
          }
        ]
      }
    ]
  }
}